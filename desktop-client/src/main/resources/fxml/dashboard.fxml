<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartforum.controllers.DashboardController">
    
    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="280" style="-fx-background-color: #f9f9f9; -fx-border-color: #ddd; -fx-border-width: 0 1 0 0;">
            <padding><Insets top="20" right="10" bottom="10" left="10" /></padding>
            
            <!-- Simple header -->
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 0 0 10 0;">Smart Forum</Label>
            
            <!-- Group List -->
            <ListView fx:id="groupListView" VBox.vgrow="ALWAYS" />
            
            <!-- Logout button -->
            <Button text="Logout" onAction="#handleLogout" 
                    style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-background-radius: 4px; -fx-padding: 8 0; -fx-margin: 10 0 0 0;" />
        </VBox>
    </left>
    
    <!-- RIGHT PANEL -->
    <center>
        <VBox style="-fx-background-color: white;">
            <!-- Header -->
            <HBox style="-fx-padding: 15; -fx-border-color: #ddd; -fx-border-width: 0 0 1 0;" alignment="CENTER_LEFT">
                <Button fx:id="backButton" text="← Back" onAction="#handleBack" visible="false" 
                        style="-fx-background-color: transparent; -fx-text-fill: #075E54; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Label fx:id="groupTitleLabel" text="Select a group" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 0 0 10;" />
            </HBox>
            
            <!-- Topic List -->
            <ListView fx:id="topicListView" VBox.vgrow="ALWAYS" />
            
            <!-- Post List (hidden initially) -->
            <ListView fx:id="postListView" VBox.vgrow="ALWAYS" visible="false" managed="false" />
            
            <!-- Status bar -->
            <Label fx:id="bottomStatusLabel" style="-fx-padding: 5 15; -fx-background-color: #f4f4f4; -fx-text-fill: #888; -fx-font-size: 12px;" text="Ready" />
        </VBox>
    </center>
</BorderPane>