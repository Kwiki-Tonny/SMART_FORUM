<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.smartforum.controllers.QuizController"
      stylesheets="@../styles/style.css">
    <padding><Insets top="20" right="20" bottom="20" left="20" /></padding>

    <HBox spacing="20" alignment="CENTER">
        <Label fx:id="quizTitle" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="timerLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #d32f2f;" />
        <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: transparent; -fx-text-fill: #888;" />
    </HBox>

    <Separator />

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox fx:id="questionsContainer" spacing="15" />
    </ScrollPane>

    <HBox alignment="CENTER_RIGHT">
        <Button text="Submit Quiz" onAction="#handleSubmit" styleClass="primary-btn" />
    </HBox>
</VBox>